# ─── TinaCloud (solo necesario para producción con TinaCloud) ───────────────
# Obtén estos valores en https://app.tina.io → tu proyecto → Overview
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# Rama de Git que usa TinaCloud como fuente de contenido
GITHUB_BRANCH=main

# ─── Notas ──────────────────────────────────────────────────────────────────
# En modo local (desarrollo) NO se necesitan estas variables.
# TinaCMS lee y escribe directamente en los archivos content/**/*.json del repo.
# Copia este archivo como .env.local y rellena los valores para activar TinaCloud.
